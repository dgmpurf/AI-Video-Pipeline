{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "CAL001_scoring.schema.json",
  "title": "CAL-001 Visual Scoring",
  "description": "P1-R2 defines scoring only. It assigns no visual scores or review outcomes.",
