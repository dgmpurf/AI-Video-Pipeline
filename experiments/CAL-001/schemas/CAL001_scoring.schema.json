        "temporal_coherence": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 5
        },
        "style_coherence": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 5
        },
        "editability": {
          "type": [
            "integer",
            "null"
          ],
          "minimum": 0,
          "maximum": 5
        }
      }
    }
  },
  "score_definitions": {
    "0": "absent or catastrophic failure",
    "1": "weak",
    "2": "partial",
    "3": "acceptable",
    "4": "strong",
    "5": "clear and reusable",
    "null": "not applicable or not yet reviewed"
  },
  "range_validation": "Every applicable score is an integer from 0 through 5; non-applicable and unreviewed scores are null, never zero.",
