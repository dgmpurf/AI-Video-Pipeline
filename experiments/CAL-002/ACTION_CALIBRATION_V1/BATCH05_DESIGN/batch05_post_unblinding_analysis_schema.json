    "family_decisions": {
      "items": false,
      "maxItems": 2,
      "minItems": 2,
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/family_decision"
            },
            {
              "properties": {
                "action_family": {
                  "const": "push_reaction"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/family_decision"
            },
            {
              "properties": {
                "action_family": {
                  "const": "brief_impact_recoil"
                }
              }
            }
          ]
        }
      ],
      "type": "array"
    },
    "mapping_source_bindings": {
      "items": false,
      "maxItems": 2,
      "minItems": 2,
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/mapping_binding"
            },
            {
              "properties": {
                "relative_path": {
                  "const": "experiments/CAL-002/ACTION_CALIBRATION_V1/BATCH05_DESIGN/batch05_design_manifest.json"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/mapping_binding"
            },
            {
              "properties": {
                "relative_path": {
                  "const": "experiments/CAL-002/ACTION_CALIBRATION_V1/BATCH05_DESIGN/batch05_task_matrix.csv"
                }
              }
            }
          ]
        }
      ],
      "type": "array"
    },
    "pair_derivations": {
      "items": false,
      "maxItems": 4,
      "minItems": 4,
      "prefixItems": [
        {
          "allOf": [
            {
              "$ref": "#/$defs/pair_derivation"
            },
            {
              "properties": {
                "pair_id": {
                  "const": "PUSH_PAIR_01"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/pair_derivation"
            },
            {
              "properties": {
                "pair_id": {
                  "const": "PUSH_PAIR_02"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/pair_derivation"
            },
            {
              "properties": {
                "pair_id": {
                  "const": "IMPACT_PAIR_01"
                }
              }
            }
          ]
        },
        {
          "allOf": [
            {
              "$ref": "#/$defs/pair_derivation"
            },
            {
              "properties": {
                "pair_id": {
                  "const": "IMPACT_PAIR_02"
                }
              }
            }
          ]
        }
      ],
      "type": "array"
    },
    "schema_version": {
      "const": "CAL002_BATCH05_POST_UNBLINDING_ANALYSIS_RECORD_V0_1"
    }
  },
  "required": [
    "schema_version",
    "blind_review_record_finalized_before_unblinding",
    "blind_review_record_sha256",
    "mapping_source_bindings",
    "pair_derivations",
    "family_decisions"
  ],
  "title": "CAL-002 Batch05 Post-Unblinding Derived Analysis Record",
  "type": "object"
}
